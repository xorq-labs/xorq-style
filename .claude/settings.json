{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "command -v xorq-check-style >/dev/null 2>&1 && printf '%s' \"$CLAUDE_TOOL_INPUT\" | xorq-check-style --hook || true"
          }
        ]
      }
    ]
  }
}
